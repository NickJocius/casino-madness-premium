# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env*.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Desktop - ignore personal config, commit project workflow
.claude/config.json           # Personal API keys, tokens
.claude/**/secrets.json       # Any secrets files
.claude/**/*.key              # Key files
.claude/**/.env*              # Environment files in .claude
.claude/settings.local.json    # personal overrides, if you ever create one
.claude/.credentials.json

# Allow project-specific Claude workflow (portfolio value)
!.claude/hooks/               # Custom hooks
!.claude/agents/              # Agent definitions
!.claude/prompts/             # Custom prompts
!.claude/mcp-servers/         # MCP server configs (if sanitized)
!.claude/README.md            # Documentation

# Prisma
prisma/*.db-journal
prisma/*.db
/generated/prisma

# Better Auth (if using file-based secrets)
auth-secret.txt
.auth-secret

# Logs that might contain sensitive data
*.log
logs/

# IDE config that might contain paths/secrets
.vscode/settings.json
.idea/
*.swp
*.swo

# Windows
Thumbs.db
Desktop.ini

# Backup files
*.backup
*.bak
*.tmp
